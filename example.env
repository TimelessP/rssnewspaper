ANTHROPIC_BASE_URL=http://localhost:1234
ANTHROPIC_AUTH_TOKEN=lmstudio
MODEL=mistral-7b-instruct-v0_3
CLAUDE_CODE_MAX_OUTPUT_TOKENS=32768
# LM Studio now also supports Anthropic /v1/messages endpoint, which is more compatible with the official Anthropic API. You can switch to it by uncommenting the line below.
ANTHROPIC_USE_MESSAGES_ENDPOINT=true
# Model-template compatibility controls:
# - Keep LMSTUDIO_USER_ONLY_PROMPT=0 for normal system-prompt behavior.
# - If a model template rejects roles during Jinja rendering, auto-retry can
#   switch to merged user-only prompt mode for that run.
LMSTUDIO_USER_ONLY_PROMPT=1
LMSTUDIO_AUTO_USER_ONLY_RETRY=1

# Optional: launch local vLLM automatically from agentic_fetcher.py
# When USE_VLLM=1, the script starts `vllm serve` and points ANTHROPIC_* to it.
USE_VLLM=0
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
VLLM_SERVED_MODEL_NAME=mistral-7b-instruct-v0_3
VLLM_HOST=127.0.0.1
VLLM_PORT=8234
# If VLLM_PORT is busy, scan upward until a free port is found (inclusive range).
VLLM_PORT_SCAN_LIMIT=20
# Internal distributed/rendezvous master port used by EngineCore (kept separate from API port).
VLLM_MASTER_PORT=8334
VLLM_MASTER_PORT_SCAN_LIMIT=100
VLLM_API_KEY=dummy
VLLM_HF_TOKEN=
# Request higher context; startup auto-adjust can lower this to your GPU-safe limit.
VLLM_MAX_MODEL_LEN=20000
VLLM_AUTO_ADJUST_MAX_MODEL_LEN=1
VLLM_GPU_MEMORY_UTILIZATION=0.9
# Fit-first profile for constrained GPUs (maps roughly to single-concurrency + smaller batch behavior).
# When enabled and values are unset below, defaults to max-num-seqs=1, max-num-batched-tokens=512, enforce-eager=1.
VLLM_FIT_PROFILE=1
# vLLM scheduler/memory knobs (leave blank to let vLLM decide)
VLLM_MAX_NUM_SEQS=
VLLM_MAX_NUM_BATCHED_TOKENS=
VLLM_ENFORCE_EAGER=1
VLLM_KV_CACHE_DTYPE=
VLLM_CPU_OFFLOAD_GB=
VLLM_SWAP_SPACE_GB=
# Model loading/quantization knobs (useful when matching GGUF/quantized style deployments)
VLLM_LOAD_FORMAT=
VLLM_QUANTIZATION=
VLLM_DTYPE=
# Optional raw passthrough args appended to `vllm serve` (advanced)
VLLM_EXTRA_ARGS=
VLLM_TOOL_CALL_PARSER=mistral
# Seconds to wait for vLLM readiness (set 0 for no timeout, useful on first model download)
VLLM_STARTUP_TIMEOUT=0

# Guardrail advisory: warns if effective vLLM context looks too small for this workflow.
# Set to 0 to disable the advisory.
AGENT_MIN_CONTEXT_TOKENS=16000
