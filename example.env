ANTHROPIC_BASE_URL=http://localhost:1234
ANTHROPIC_AUTH_TOKEN=lmstudio
MODEL=mistralai/ministral-3-3b
CLAUDE_CODE_MAX_OUTPUT_TOKENS=20000
# LM Studio now also supports Anthropic /v1/messages endpoint, which is more compatible with the official Anthropic API. You can switch to it by uncommenting the line below.
ANTHROPIC_USE_MESSAGES_ENDPOINT=true

# Optional: launch local vLLM automatically from agentic_fetcher.py
# When USE_VLLM=1, the script starts `vllm serve` and points ANTHROPIC_* to it.
USE_VLLM=1
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
VLLM_SERVED_MODEL_NAME=mistral-7b-instruct-v0_3
VLLM_HOST=127.0.0.1
VLLM_PORT=8234
# If VLLM_PORT is busy, scan upward until a free port is found (inclusive range).
VLLM_PORT_SCAN_LIMIT=20
# Internal distributed/rendezvous master port used by EngineCore (kept separate from API port).
VLLM_MASTER_PORT=8334
VLLM_MASTER_PORT_SCAN_LIMIT=100
VLLM_API_KEY=dummy
VLLM_HF_TOKEN=
VLLM_MAX_MODEL_LEN=20000
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_TOOL_CALL_PARSER=mistral
# Seconds to wait for vLLM readiness (set 0 for no timeout, useful on first model download)
VLLM_STARTUP_TIMEOUT=0
