<!-- ═══════════════════════════════════════════════════════════════════════
     Article Sections (grouped by category)
     ═══════════════════════════════════════════════════════════════════════ -->
{% for cat, articles in categories_articles.items() %}
<section class="category-section" data-category="{{ cat }}">
  <div class="section-header">
    <div class="section-header__inner">
      <svg class="icon icon-lg section-header__icon"><use href="#icon-{{ category_icons.get(cat, 'article') }}"/></svg>
      <h2 class="section-header__title">{{ cat }}</h2>
      <hr class="section-header__rule">
      <span class="section-header__count">{{ articles | length }} {{ "article" if articles | length == 1 else "articles" }}</span>
    </div>
  </div>

  <div class="card-grid" data-category="{{ cat }}">
    {% for article in articles %}
    <article class="card"
             data-idx="{{ article._idx }}"
             data-category="{{ article.category }}"
             data-feed="{{ article.feed_name }}"
             data-kind="{{ article.content_kind }}"
             data-media="{{ article._media_flags }}"
             data-tags="{{ article.tags | join(',') | lower }}"
             data-searchable="{{ article.title | lower }} {{ article.feed_name | lower }} {{ article.author | lower }} {{ article.summary_plain | lower }} {{ article.tags | join(' ') | lower }}">

      <div class="card__image-wrap" onclick="openArticle({{ article._idx }})">
        {% if article.image_url %}
        <img src="{{ article.image_url }}" alt="" loading="lazy"
             onerror="this.parentElement.innerHTML='<div class=\'card__image-placeholder\'><svg class=\'icon icon-xl\'><use href=\'#icon-image\'/></svg></div>'">
        {% else %}
        <div class="card__image-placeholder">
          <svg class="icon icon-xl"><use href="#icon-image"/></svg>
        </div>
        {% endif %}
        {% if article.content_kind != "article" %}
        <span class="card__kind-badge">
          <svg class="icon" style="width:0.8em;height:0.8em"><use href="#icon-{{ article.content_kind }}"/></svg>
          {{ article.content_kind }}
        </span>
        {% endif %}
        {% if article._has_audio %}
        <span class="card__media-badge card__media-badge--audio">
          <svg class="icon" style="width:0.8em;height:0.8em"><use href="#icon-podcast"/></svg>
          MP3
        </span>
        {% endif %}
        {% if article._has_youtube %}
        <span class="card__media-badge card__media-badge--youtube">
          <svg class="icon" style="width:0.8em;height:0.8em"><use href="#icon-video"/></svg>
          YouTube
        </span>
        {% endif %}
        {% if article._has_video and not article._has_youtube %}
        <span class="card__media-badge card__media-badge--video">
          <svg class="icon" style="width:0.8em;height:0.8em"><use href="#icon-video"/></svg>
          Video
        </span>
        {% endif %}
      </div>

      <div class="card__body" onclick="openArticle({{ article._idx }})">
        <span class="card__feed">{{ article.feed_name }}</span>
        <h3 class="card__title">
          <a href="{{ article.canonical_url }}" target="_blank" rel="noopener" onclick="event.stopPropagation()">{{ article.title }}</a>
        </h3>
        <div class="card__meta">
          <span class="card__meta-item">
            <svg class="icon"><use href="#icon-calendar"/></svg>
            {{ article.published_display }}
          </span>
          {% if article.author and article.author != "Unknown" %}
          <span class="card__meta-item">
            <svg class="icon"><use href="#icon-user"/></svg>
            {{ article.author }}
          </span>
          {% endif %}
        </div>
        <p class="card__summary">{{ article.summary_plain }}</p>
      </div>

      {% if article.tags %}
      <div class="card__tags">
        {% for tag in article.tags[:6] %}
        <span class="card__tag" onclick="searchByTag('{{ tag }}')">{{ tag }}</span>
        {% endfor %}
      </div>
      {% endif %}

      <div class="card__footer">
        <a class="card__read-link" href="{{ article.canonical_url }}" target="_blank" rel="noopener">
          Read full article
          <svg class="icon"><use href="#icon-arrow-right"/></svg>
        </a>
      </div>
    </article>
    {% endfor %}
  </div>
</section>
{% endfor %}


