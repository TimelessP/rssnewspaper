<!-- ═══════════════════════════════════════════════════════════════════════
     Theme Switcher — System / Light / Dark
     Applied early to prevent flash of wrong theme
     ═══════════════════════════════════════════════════════════════════════ -->
<script>
(function() {
  'use strict';
  var THEME_KEY = 'newspaper-theme';
  var saved = localStorage.getItem(THEME_KEY) || 'system';

  function resolveTheme(pref) {
    if (pref === 'dark') return 'dark';
    if (pref === 'light') return 'light';
    // system — follow OS
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function applyTheme(pref) {
    var resolved = resolveTheme(pref);
    document.documentElement.setAttribute('data-theme', resolved === 'dark' ? 'dark' : '');
    // Update switcher button states
    var btns = document.querySelectorAll('.theme-switcher__btn');
    btns.forEach(function(b) {
      b.classList.toggle('active', b.dataset.themeValue === pref);
    });
  }

  // Initial apply
  applyTheme(saved);

  // Listen for clicks
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.theme-switcher__btn');
    if (!btn) return;
    var pref = btn.dataset.themeValue;
    localStorage.setItem(THEME_KEY, pref);
    applyTheme(pref);
  });

  // Re-evaluate if OS preference changes while on "system"
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function() {
    var current = localStorage.getItem(THEME_KEY) || 'system';
    if (current === 'system') applyTheme('system');
  });
})();
</script>


<!-- ═══════════════════════════════════════════════════════════════════════
     Application JavaScript — Search, Filters, Views, Modal
     ═══════════════════════════════════════════════════════════════════════ -->
<script>
(function() {
  'use strict';

  // ── State ──────────────────────────────────────────────────────────
  let currentView = 'grid';
  let currentCategory = 'all';
  let currentKind = 'all';
  let currentMedia = '';      // '' = no media filter
  let currentTag = '';        // '' = no tag filter
  let searchTerm = '';

  // ── Elements ───────────────────────────────────────────────────────
  const searchInput   = document.getElementById('searchInput');
  const searchClear   = document.getElementById('searchClear');
  const articleCount  = document.getElementById('articleCount');
  const noResults     = document.getElementById('noResults');
  const modalOverlay  = document.getElementById('modalOverlay');
  const backToTop     = document.getElementById('backToTop');

  const allCards      = document.querySelectorAll('.card');
  const allSections   = document.querySelectorAll('.category-section');
  const allGrids      = document.querySelectorAll('.card-grid');
  const viewBtns      = document.querySelectorAll('.toolbar__view-btn');
  const catBtns       = document.querySelectorAll('.toolbar__filter-btn[data-category]');
  const kindBtns      = document.querySelectorAll('.toolbar__filter-btn[data-kind]');
  const mediaBtns     = document.querySelectorAll('.toolbar__filter-btn[data-media]');
  const tagBtns       = document.querySelectorAll('.tag-cloud__tag');

  // ── Search ─────────────────────────────────────────────────────────
  searchInput.addEventListener('input', function() {
    searchTerm = this.value.trim().toLowerCase();
    searchClear.classList.toggle('visible', searchTerm.length > 0);
    applyFilters();
  });

  searchClear.addEventListener('click', function() {
    searchInput.value = '';
    searchTerm = '';
    searchClear.classList.remove('visible');
    applyFilters();
    searchInput.focus();
  });

  // Keyboard shortcut: / to focus search, Esc to close modal or blur
  document.addEventListener('keydown', function(e) {
    if (e.key === '/' && document.activeElement !== searchInput) {
      e.preventDefault();
      searchInput.focus();
    }
    if (e.key === 'Escape') {
      if (modalOverlay.classList.contains('open')) {
        closeArticle();
      } else if (document.activeElement === searchInput) {
        searchInput.blur();
      }
    }
  });

  // ── Category Filters ──────────────────────────────────────────────
  catBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      catBtns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentCategory = btn.dataset.category;
      applyFilters();
    });
  });

  // ── Content Kind Filters ──────────────────────────────────────────
  kindBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      kindBtns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentKind = btn.dataset.kind;
      applyFilters();
    });
  });

  // ── Media Filters (toggle behaviour) ──────────────────────────────
  mediaBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (btn.classList.contains('active')) {
        btn.classList.remove('active');
        currentMedia = '';
      } else {
        mediaBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        currentMedia = btn.dataset.media;
      }
      applyFilters();
    });
  });

  // ── Tag Cloud Filters (toggle behaviour) ──────────────────────────
  tagBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (btn.classList.contains('active')) {
        btn.classList.remove('active');
        currentTag = '';
      } else {
        tagBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        currentTag = btn.dataset.tag;
      }
      applyFilters();
    });
  });

  // ── View Toggle ───────────────────────────────────────────────────
  viewBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      viewBtns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentView = btn.dataset.view;
      applyView();
    });
  });

  function applyView() {
    allGrids.forEach(function(grid) {
      grid.classList.toggle('card-grid--headlines', currentView === 'headlines');
    });
    allCards.forEach(function(card) {
      card.classList.toggle('card--headline', currentView === 'headlines');
    });
  }

  // ── Filter Logic ──────────────────────────────────────────────────
  function applyFilters() {
    let visibleCount = 0;

    allCards.forEach(function(card) {
      const matchesCategory = currentCategory === 'all' || card.dataset.category === currentCategory;
      const matchesKind = currentKind === 'all' || card.dataset.kind === currentKind;
      const matchesMedia = !currentMedia || (card.dataset.media && card.dataset.media.indexOf(currentMedia) !== -1);
      const matchesTag = !currentTag || (card.dataset.tags && card.dataset.tags.indexOf(currentTag) !== -1);
      const matchesSearch = !searchTerm || card.dataset.searchable.includes(searchTerm);
      const visible = matchesCategory && matchesKind && matchesMedia && matchesTag && matchesSearch;

      card.classList.toggle('hidden', !visible);
      if (visible) visibleCount++;
    });

    // Show/hide category sections
    allSections.forEach(function(section) {
      const cat = section.dataset.category;
      const matchesCatFilter = currentCategory === 'all' || cat === currentCategory;
      const hasVisible = section.querySelectorAll('.card:not(.hidden)').length > 0;
      section.classList.toggle('hidden', !matchesCatFilter || !hasVisible);

      const countEl = section.querySelector('.section-header__count');
      if (countEl) {
        const cnt = section.querySelectorAll('.card:not(.hidden)').length;
        countEl.textContent = cnt + (cnt === 1 ? ' article' : ' articles');
      }
    });

    articleCount.textContent = visibleCount + (visibleCount === 1 ? ' article' : ' articles');
    noResults.classList.toggle('visible', visibleCount === 0);
    updateActiveHint();
  }

  // ── Tag Search (from card tag clicks) ─────────────────────────────
  window.searchByTag = function(tag) {
    // Activate the tag in the tag cloud if it exists
    var found = false;
    tagBtns.forEach(function(btn) {
      if (btn.dataset.tag === tag.toLowerCase()) {
        tagBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        currentTag = btn.dataset.tag;
        found = true;
      }
    });
    // If not in tag cloud, use text search
    if (!found) {
      searchInput.value = tag;
      searchTerm = tag.toLowerCase();
      searchClear.classList.add('visible');
    }
    // Reset category to All
    catBtns.forEach(function(b) { b.classList.remove('active'); });
    catBtns[0].classList.add('active');
    currentCategory = 'all';
    applyFilters();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  // ── Reset All Filters ─────────────────────────────────────────────
  window.resetFilters = function() {
    searchInput.value = '';
    searchTerm = '';
    searchClear.classList.remove('visible');
    currentCategory = 'all';
    currentKind = 'all';
    currentMedia = '';
    currentTag = '';
    catBtns.forEach(function(b) { b.classList.remove('active'); });
    catBtns[0].classList.add('active');
    kindBtns.forEach(function(b) { b.classList.remove('active'); });
    mediaBtns.forEach(function(b) { b.classList.remove('active'); });
    tagBtns.forEach(function(b) { b.classList.remove('active'); });
    applyFilters();
  };

  // ── Modal ─────────────────────────────────────────────────────────
  window.openArticle = function(idx) {
    const article = ARTICLES[idx];
    if (!article) return;

    // Hero image
    const heroEl = document.getElementById('modalHero');
    if (article.image_url) {
      heroEl.innerHTML = '<img src="' + article.image_url + '" alt="" onerror="this.parentElement.style.display=\'none\'">';
      heroEl.style.display = '';
    } else {
      heroEl.style.display = 'none';
    }

    // Feed
    document.getElementById('modalFeed').textContent = article.feed_name + ' \u2022 ' + article.category;

    // Title
    document.getElementById('modalTitle').textContent = article.title;

    // Meta
    const metaEl = document.getElementById('modalMeta');
    let metaHtml = '';
    metaHtml += '<span class="modal__meta-item"><svg class="icon"><use href="#icon-calendar"/></svg>' + article.published_display + '</span>';
    if (article.author && article.author !== 'Unknown') {
      metaHtml += '<span class="modal__meta-item"><svg class="icon"><use href="#icon-user"/></svg>' + escapeHtml(article.author) + '</span>';
    }
    metaHtml += '<span class="modal__meta-item"><svg class="icon"><use href="#icon-rss"/></svg>' + escapeHtml(article.feed_name) + '</span>';
    if (article.content_kind !== 'article') {
      metaHtml += '<span class="modal__meta-item"><svg class="icon"><use href="#icon-' + article.content_kind + '"/></svg>' + article.content_kind.charAt(0).toUpperCase() + article.content_kind.slice(1) + '</span>';
    }
    metaEl.innerHTML = metaHtml;

    // Body
    const bodyEl = document.getElementById('modalBody');
    let bodyHtml = '';

    // Media assets section
    if (article.media_assets && article.media_assets.length > 0) {
      bodyHtml += '<div style="margin-bottom:1rem;padding:0.75rem;border:1px solid var(--rule);border-radius:2px;background:var(--paper-dark)">';
      bodyHtml += '<p style="font-family:var(--font-mono);font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-faded);margin-bottom:0.5rem">';
      bodyHtml += '<svg class="icon" style="vertical-align:-2px"><use href="#icon-podcast"/></svg> Media</p>';
      article.media_assets.forEach(function(ma) {
        var icon = ma.kind === 'youtube' ? 'video' : 'podcast';
        var label = ma.title || (ma.kind === 'youtube' ? 'Watch on YouTube' : ma.kind === 'audio' ? 'Listen (MP3)' : 'Play media');
        bodyHtml += '<a href="' + ma.url + '" target="_blank" rel="noopener" class="modal__action-btn" style="margin:0.25rem 0.25rem 0.25rem 0;display:inline-flex">';
        bodyHtml += '<svg class="icon"><use href="#icon-' + icon + '"/></svg> ' + escapeHtml(label);
        if (ma.duration_seconds) {
          var mins = Math.floor(ma.duration_seconds / 60);
          bodyHtml += ' <span style="opacity:0.6">(' + mins + 'min)</span>';
        }
        bodyHtml += '</a>';
      });
      bodyHtml += '</div>';
    }

    if (article.content_html) {
      bodyHtml += article.content_html;
    } else if (article.summary) {
      bodyHtml += '<p>' + escapeHtml(article.summary) + '</p>';
    } else {
      bodyHtml += '<p style="color:var(--ink-ghost);font-style:italic">No content available for this article.</p>';
    }
    bodyEl.innerHTML = bodyHtml;

    // Tags
    const tagsEl = document.getElementById('modalTags');
    if (article.tags && article.tags.length) {
      tagsEl.innerHTML = article.tags.map(function(t) {
        return '<span class="card__tag" onclick="closeArticle(); searchByTag(\'' + escapeHtml(t).replace(/'/g, "\\'") + '\')">' + escapeHtml(t) + '</span>';
      }).join('');
    } else {
      tagsEl.innerHTML = '';
    }

    // Actions
    const actionsEl = document.getElementById('modalActions');
    var actionsHtml =
      '<a class="modal__action-btn modal__action-btn--primary" href="' + article.canonical_url + '" target="_blank" rel="noopener">' +
      '<svg class="icon"><use href="#icon-external"/></svg> Read Original</a>' +
      '<button class="modal__action-btn" onclick="shareArticle(' + idx + ')">' +
      '<svg class="icon"><use href="#icon-share"/></svg> Share</button>';
    actionsHtml += '<div class="modal__url-row">' +
      '<svg class="icon" style="width:0.7em;height:0.7em;flex-shrink:0;color:var(--ink-ghost)"><use href="#icon-rss"/></svg>' +
      '<a class="modal__url-link" href="' + article.feed_url + '" target="_blank" rel="noopener" title="' + escapeHtml(article.feed_url) + '">' + escapeHtml(article.feed_url) + '</a>' +
      '<button class="modal__copy-btn" onclick="copyUrl(this, \'' + article.feed_url.replace(/'/g, "\\'") + '\')" title="Copy feed URL">' +
      '<svg class="icon" style="width:0.85em;height:0.85em"><use href="#icon-copy"/></svg></button>' +
      '</div>';
    actionsEl.innerHTML = actionsHtml;

    // Show
    modalOverlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  };

  window.closeArticle = function() {
    modalOverlay.classList.remove('open');
    document.body.style.overflow = '';
  };

  modalOverlay.addEventListener('click', function(e) {
    if (e.target === modalOverlay) closeArticle();
  });

  // ── Filter Panel Toggle ───────────────────────────────────────────
  const filterToggle = document.getElementById('filterToggle');
  const filterPanel  = document.getElementById('filterPanel');
  const activeHint   = document.getElementById('activeFilterHint');

  filterToggle.addEventListener('click', function() {
    const isOpen = filterToggle.classList.toggle('open');
    filterPanel.classList.toggle('collapsed', !isOpen);
  });

  function updateActiveHint() {
    const parts = [];
    if (currentCategory !== 'all') parts.push(currentCategory);
    if (currentKind !== 'all') parts.push(currentKind);
    if (currentMedia) parts.push(currentMedia);
    if (currentTag) parts.push('#' + currentTag);
    activeHint.textContent = parts.length ? parts.join(' \u00b7 ') : '';
  }

  // ── Back to Top ───────────────────────────────────────────────────
  window.addEventListener('scroll', function() {
    backToTop.classList.toggle('visible', window.scrollY > 400);
  });

  backToTop.addEventListener('click', function() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // ── Utility ───────────────────────────────────────────────────────
  function escapeHtml(str) {
    if (!str) return '';
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // ── Copy URL to Clipboard ─────────────────────────────────────────
  window.copyUrl = function(btn, url) {
    navigator.clipboard.writeText(url).then(function() {
      btn.classList.add('copied');
      btn.innerHTML = '<svg class="icon" style="width:0.85em;height:0.85em"><use href="#icon-check"/></svg>';
      setTimeout(function() {
        btn.classList.remove('copied');
        btn.innerHTML = '<svg class="icon" style="width:0.85em;height:0.85em"><use href="#icon-copy"/></svg>';
      }, 1500);
    });
  };

  // ── Share Article ─────────────────────────────────────────────────
  window.shareArticle = function(idx) {
    const article = ARTICLES[idx];
    if (!article) return;
    const shareData = {
      title: article.title,
      text: article.title + ' — ' + article.feed_name,
      url: article.canonical_url
    };
    if (navigator.share) {
      navigator.share(shareData).catch(function() {});
    } else {
      // Fallback: copy URL to clipboard
      navigator.clipboard.writeText(article.canonical_url).then(function() {
        var btn = document.querySelector('.modal__actions .modal__action-btn:nth-child(2)');
        if (btn) {
          btn.innerHTML = '<svg class="icon"><use href="#icon-check"/></svg> Copied';
          btn.style.color = 'var(--accent)';
          setTimeout(function() {
            btn.innerHTML = '<svg class="icon"><use href="#icon-share"/></svg> Share';
            btn.style.color = '';
          }, 1500);
        }
      });
    }
  };

})();
</script>

</body>
</html>
