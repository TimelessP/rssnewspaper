<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Daily Wire &mdash; {{ generation_date_display }}</title>
<script>
// Apply theme before CSS renders to prevent flash of wrong theme
(function(){var t=localStorage.getItem('newspaper-theme')||'system';var d=(t==='dark'||(t==='system'&&window.matchMedia('(prefers-color-scheme: dark)').matches));if(d)document.documentElement.setAttribute('data-theme','dark');})();
</script>
<style>
/* ═══════════════════════════════════════════════════════════════════════════
   THE DAILY WIRE — Old-Time Newspaper · Art-Game Aesthetic
   Desaturated palette · Vector icons · Self-contained
   ═══════════════════════════════════════════════════════════════════════════ */

/* ── CSS Reset & Base ─────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  /* Desaturated old-paper palette */
  --paper:        #f2ebe0;
  --paper-dark:   #e8dece;
  --paper-edge:   #d4c5ad;
  --ink:          #2c2416;
  --ink-light:    #5a4e3c;
  --ink-faded:    #8a7e6c;
  --ink-ghost:    #b0a690;
  --accent:       #8b3a3a;
  --accent-hover: #a04545;
  --accent-pale:  #c49a7a;
  --rule:         #a09480;
  --rule-heavy:   #6e6354;
  --shadow:       rgba(44, 36, 22, 0.12);
  --shadow-deep:  rgba(44, 36, 22, 0.25);

  /* Typography scale */
  --font-serif:    'Georgia', 'Times New Roman', 'Palatino', serif;
  --font-display:  'Georgia', 'Palatino Linotype', serif;
  --font-mono:     'Courier New', 'Courier', monospace;

  /* Layout */
  --max-width: 1400px;
  --gutter: 1.5rem;
  --card-radius: 2px;

  /* Texture overlay opacity */
  --texture-opacity: 0.04;
}

html {
  font-size: 32px;
  -webkit-font-smoothing: antialiased;
}

body {
  font-family: var(--font-serif);
  background: var(--paper);
  color: var(--ink);
  line-height: 1.65;
  min-height: 100vh;
  position: relative;
}

/* Paper texture overlay */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 9999;
  opacity: var(--texture-opacity);
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(44, 36, 22, 0.03) 2px,
      rgba(44, 36, 22, 0.03) 4px
    ),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 3px,
      rgba(44, 36, 22, 0.02) 3px,
      rgba(44, 36, 22, 0.02) 6px
    );
}

a { color: var(--accent); text-decoration: none; transition: color 0.2s; }
a:hover { color: var(--accent-hover); text-decoration: underline; }

img { max-width: 100%; height: auto; display: block; }

::selection { background: var(--accent-pale); color: var(--ink); }

/* ── SVG Icon Definitions (hidden) ────────────────────────────────────── */
.svg-defs { position: absolute; width: 0; height: 0; overflow: hidden; }

.icon {
  display: inline-block;
  width: 1em;
  height: 1em;
  vertical-align: -0.125em;
  fill: currentColor;
  stroke: none;
}
.icon-lg { width: 1.5em; height: 1.5em; }
.icon-xl { width: 2em; height: 2em; }


/* ── Masthead ─────────────────────────────────────────────────────────── */
.masthead {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 2rem var(--gutter) 0;
  text-align: center;
  position: relative;
}

.masthead__rule-top {
  border: none;
  border-top: 3px double var(--rule-heavy);
  margin-bottom: 0.75rem;
}

.masthead__dateline {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ink-faded);
  margin-bottom: 0.25rem;
}

.masthead__title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: 700;
  letter-spacing: 0.04em;
  line-height: 1.05;
  color: var(--ink);
  text-transform: uppercase;
  margin: 0.25rem 0;
  text-shadow: 1px 1px 0 var(--paper-dark);
}

.masthead__subtitle {
  font-style: italic;
  font-size: 1rem;
  color: var(--ink-faded);
  margin-bottom: 0.25rem;
}

.masthead__stats {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  color: var(--ink-ghost);
  margin-bottom: 0.75rem;
}

.masthead__rule-bottom {
  border: none;
  border-top: 1px solid var(--rule);
  margin-bottom: 0;
}

/* Decorative corner flourishes */
.masthead__flourish {
  position: absolute;
  width: 60px;
  height: 60px;
  opacity: 0.2;
}
.masthead__flourish--tl { top: 0.5rem; left: var(--gutter); }
.masthead__flourish--tr { top: 0.5rem; right: var(--gutter); transform: scaleX(-1); }


/* ── Navigation / Toolbar ─────────────────────────────────────────────── */
.toolbar {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 0.75rem var(--gutter);
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.75rem;
  border-bottom: 1px solid var(--rule);
  position: sticky;
  top: 0;
  background: var(--paper);
  z-index: 100;
  backdrop-filter: blur(2px);
}

.toolbar__search {
  flex: 1 1 260px;
  position: relative;
}

.toolbar__search-input {
  width: 100%;
  padding: 0.5rem 0.75rem 0.5rem 2.25rem;
  font-family: var(--font-serif);
  font-size: 0.9rem;
  border: 1px solid var(--rule);
  border-radius: var(--card-radius);
  background: var(--paper);
  color: var(--ink);
  transition: border-color 0.2s, box-shadow 0.2s;
  outline: none;
}
.toolbar__search-input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 2px rgba(139, 58, 58, 0.15);
}
.toolbar__search-input::placeholder { color: var(--ink-ghost); font-style: italic; }

.toolbar__search-icon {
  position: absolute;
  left: 0.6rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--ink-ghost);
  pointer-events: none;
}

.toolbar__search-clear {
  position: absolute;
  right: 0.5rem;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  color: var(--ink-ghost);
  cursor: pointer;
  padding: 0.25rem;
  display: none;
  font-size: 1rem;
  line-height: 1;
}
.toolbar__search-clear.visible { display: block; }
.toolbar__search-clear:hover { color: var(--accent); }

.toolbar__filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  align-items: center;
}

.toolbar__filter-btn {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.35rem 0.7rem;
  border: 1px solid var(--rule);
  border-radius: var(--card-radius);
  background: transparent;
  color: var(--ink-faded);
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
}
.toolbar__filter-btn:hover {
  border-color: var(--ink-light);
  color: var(--ink-light);
}
.toolbar__filter-btn.active {
  background: var(--ink);
  color: var(--paper);
  border-color: var(--ink);
}

/* Content-type filter accent colours */
.toolbar__filter-btn[data-kind="podcast"].active,
.toolbar__filter-btn[data-media="audio"].active {
  background: #6b5b3e;
  border-color: #6b5b3e;
}
.toolbar__filter-btn[data-kind="video"].active,
.toolbar__filter-btn[data-media="video"].active,
.toolbar__filter-btn[data-media="youtube"].active {
  background: var(--accent);
  border-color: var(--accent);
}

/* ── Collapsible Filter Panel ─────────────────────────────────────────── */
.filter-panel {
  max-width: var(--max-width);
  margin: 0 auto;
  overflow: hidden;
  transition: max-height 0.3s ease, opacity 0.25s ease, padding 0.3s ease;
  max-height: 60rem;          /* generous open height */
  opacity: 1;
  padding: 0.4rem var(--gutter) 0.5rem;
  border-bottom: 1px solid var(--rule);
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.filter-panel.collapsed {
  max-height: 0;
  opacity: 0;
  padding-top: 0;
  padding-bottom: 0;
  border-bottom-color: transparent;
}

.toolbar__toggle {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.25rem 0.6rem;
  border: 1px solid var(--rule);
  border-radius: var(--card-radius);
  background: transparent;
  color: var(--ink-faded);
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
}
.toolbar__toggle:hover { border-color: var(--ink-light); color: var(--ink-light); }
.toolbar__toggle .chevron {
  display: inline-block;
  transition: transform 0.3s;
  font-size: 0.7em;
}
.toolbar__toggle.open .chevron { transform: rotate(180deg); }

.toolbar__active-filters {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  color: var(--accent);
  letter-spacing: 0.06em;
}

/* ── Filter Rows ──────────────────────────────────────────────────────── */
.toolbar__row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  align-items: center;
  width: 100%;
}

.toolbar__row-label {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-ghost);
  min-width: 5rem;
  flex-shrink: 0;
}

.toolbar__separator {
  width: 1px;
  height: 1.2rem;
  background: var(--rule);
  flex-shrink: 0;
}

/* ── Tag Cloud (inside filter panel) ──────────────────────────────────── */
.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  align-items: center;
}

.tag-cloud__label {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-ghost);
  margin-right: 0.5rem;
  flex-shrink: 0;
}

.tag-cloud__tag {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.03em;
  color: var(--ink-faded);
  border: 1px solid var(--paper-edge);
  padding: 0.15rem 0.45rem;
  border-radius: 1px;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
  background: transparent;
}
.tag-cloud__tag:hover {
  border-color: var(--accent);
  color: var(--accent);
}
.tag-cloud__tag.active {
  background: var(--accent);
  color: var(--paper);
  border-color: var(--accent);
}
.tag-cloud__tag .tag-count {
  font-size: 0.55rem;
  opacity: 0.6;
  margin-left: 0.2rem;
}

.tag-cloud__toggle {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--accent);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.15rem 0.4rem;
  text-decoration: underline;
}

/* ── Media Badges on Cards ────────────────────────────────────────────── */
.card__media-badge {
  position: absolute;
  bottom: 0.5rem;
  left: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.55rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.15rem 0.4rem;
  border-radius: 1px;
  display: flex;
  align-items: center;
  gap: 0.2rem;
}
.card__media-badge--audio {
  background: #6b5b3e;
  color: var(--paper);
}
.card__media-badge--youtube {
  background: #8b3a3a;
  color: var(--paper);
}
.card__media-badge--video {
  background: #5a4e3c;
  color: var(--paper);
}
/* Stack multiple badges */
.card__media-badge + .card__media-badge {
  left: auto;
  right: 0.5rem;
}

.toolbar__view-btns {
  display: flex;
  gap: 0.25rem;
  margin-left: auto;
}

.toolbar__view-btn {
  background: none;
  border: 1px solid var(--rule);
  border-radius: var(--card-radius);
  padding: 0.35rem 0.5rem;
  cursor: pointer;
  color: var(--ink-faded);
  transition: all 0.2s;
  display: flex;
  align-items: center;
}
.toolbar__view-btn:hover { border-color: var(--ink-light); color: var(--ink-light); }
.toolbar__view-btn.active { background: var(--ink); color: var(--paper); border-color: var(--ink); }

.toolbar__count {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--ink-ghost);
  white-space: nowrap;
}


/* ── Category Section Headers ─────────────────────────────────────────── */
.section-header {
  max-width: var(--max-width);
  margin: 2rem auto 1rem;
  padding: 0 var(--gutter);
}

.section-header__inner {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.section-header__icon {
  color: var(--accent);
  flex-shrink: 0;
}

.section-header__title {
  font-family: var(--font-display);
  font-size: 1.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--ink);
}

.section-header__rule {
  flex: 1;
  border: none;
  border-top: 2px solid var(--rule-heavy);
}

.section-header__count {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--ink-ghost);
  white-space: nowrap;
}


/* ── Card Grid ────────────────────────────────────────────────────────── */
.card-grid {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 0 var(--gutter);
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1.5rem;
}

.card-grid--headlines {
  grid-template-columns: 1fr;
}


/* ── Article Card ─────────────────────────────────────────────────────── */
.card {
  background: var(--paper);
  border: 1px solid var(--paper-edge);
  border-radius: var(--card-radius);
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
  display: flex;
  flex-direction: column;
  position: relative;
  cursor: default;
}
.card:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 16px var(--shadow), 0 1px 4px var(--shadow-deep);
}

.card__image-wrap {
  position: relative;
  overflow: hidden;
  background: var(--paper-dark);
  aspect-ratio: 16 / 9;
}
.card__image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: saturate(0.55) contrast(1.05) sepia(0.15);
  transition: filter 0.3s;
}
.card:hover .card__image-wrap img {
  filter: saturate(0.75) contrast(1.05) sepia(0.08);
}
.card__image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ink-ghost);
}

.card__kind-badge {
  position: absolute;
  top: 0.5rem;
  left: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: var(--ink);
  color: var(--paper);
  padding: 0.2rem 0.5rem;
  border-radius: 1px;
}

.card__body {
  padding: 1rem 1.2rem;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card__feed {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 0.4rem;
}

.card__title {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 0.5rem;
  color: var(--ink);
}
.card__title a {
  color: inherit;
  text-decoration: none;
}
.card__title a:hover {
  color: var(--accent);
}

.card__meta {
  font-size: 0.78rem;
  color: var(--ink-faded);
  margin-bottom: 0.6rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  align-items: center;
}
.card__meta-item {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

.card__summary {
  font-size: 0.88rem;
  color: var(--ink-light);
  line-height: 1.55;
  flex: 1;
  /* Clamp to ~4 lines */
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-top: 0.75rem;
  padding-top: 0.6rem;
  border-top: 1px solid var(--paper-edge);
}

.card__tag {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.05em;
  color: var(--ink-ghost);
  border: 1px solid var(--paper-edge);
  padding: 0.15rem 0.4rem;
  border-radius: 1px;
  cursor: pointer;
  transition: all 0.2s;
}
.card__tag:hover {
  border-color: var(--accent);
  color: var(--accent);
}

.card__footer {
  padding: 0.6rem 1.2rem;
  border-top: 1px solid var(--paper-edge);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card__read-link {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
  display: flex;
  align-items: center;
  gap: 0.35rem;
}
.card__read-link:hover { text-decoration: none; color: var(--accent-hover); }

.card__read-link .icon { transition: transform 0.2s; }
.card__read-link:hover .icon { transform: translateX(3px); }


/* ── Headlines View (list mode) ──────────────────────────────────────── */
.card--headline {
  flex-direction: row;
  gap: 0;
}
.card--headline .card__image-wrap {
  width: 200px;
  min-width: 200px;
  aspect-ratio: auto;
}
.card--headline .card__body {
  padding: 0.8rem 1rem;
}
.card--headline .card__title { font-size: 1rem; }
.card--headline .card__summary { -webkit-line-clamp: 2; }
.card--headline .card__tags { display: none; }
.card--headline .card__footer { display: none; }


/* ── Article Modal / Expanded View ────────────────────────────────────── */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(44, 36, 22, 0.65);
  z-index: 1000;
  display: none;
  align-items: flex-start;
  justify-content: center;
  overflow-y: auto;
  padding: 3rem 1rem;
  backdrop-filter: blur(3px);
}
.modal-overlay.open { display: flex; }

.modal {
  background: var(--paper);
  border: 1px solid var(--paper-edge);
  border-radius: var(--card-radius);
  max-width: 800px;
  width: 100%;
  position: relative;
  box-shadow: 0 16px 64px var(--shadow-deep);
  animation: modalIn 0.25s ease-out;
}

@keyframes modalIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.modal__close {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: var(--paper-dark);
  border: 1px solid var(--rule);
  width: 2rem;
  height: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  border-radius: 50%;
  color: var(--ink-faded);
  transition: all 0.2s;
  z-index: 10;
}
.modal__close:hover { background: var(--ink); color: var(--paper); }

.modal__hero {
  width: 100%;
  aspect-ratio: 2 / 1;
  overflow: hidden;
  background: var(--paper-dark);
}
.modal__hero img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: saturate(0.6) contrast(1.05) sepia(0.12);
}

.modal__content {
  padding: 2rem 2.5rem;
}

.modal__feed {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 0.5rem;
}

.modal__title {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 0.75rem;
  color: var(--ink);
}

.modal__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  font-size: 0.82rem;
  color: var(--ink-faded);
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--rule);
}
.modal__meta-item {
  display: flex;
  align-items: center;
  gap: 0.3rem;
}

.modal__body {
  font-size: 0.95rem;
  line-height: 1.75;
  color: var(--ink-light);
}
.modal__body p { margin-bottom: 1rem; }
.modal__body a { color: var(--accent); text-decoration: underline; }
.modal__body img {
  margin: 1rem 0;
  border: 1px solid var(--paper-edge);
  filter: saturate(0.6) sepia(0.1);
}

.modal__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-top: 1.5rem;
  padding-top: 1rem;
  border-top: 1px solid var(--rule);
}

.modal__actions {
  margin-top: 1.5rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  align-items: center;
}

.modal__action-btn {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.5rem 1.2rem;
  border: 1px solid var(--rule);
  background: transparent;
  color: var(--ink-faded);
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  text-decoration: none;
}
.modal__action-btn:hover {
  background: var(--ink);
  color: var(--paper);
  border-color: var(--ink);
  text-decoration: none;
}

.modal__action-btn--primary {
  background: var(--accent);
  color: var(--paper);
  border-color: var(--accent);
}
.modal__action-btn--primary:hover {
  background: var(--accent-hover);
  border-color: var(--accent-hover);
}

/* ── Modal URL Row ───────────────────────────────────────────────────── */
.modal__url-row {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.35rem 0.55rem;
  background: var(--paper-dark);
  border: 1px solid var(--rule);
  border-radius: var(--card-radius);
  min-width: 0;
  width: 100%;
  flex-basis: 100%;
}
.modal__url-link {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--ink-faded);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  min-width: 0;
  text-decoration: none;
}
.modal__url-link:hover {
  color: var(--accent);
  text-decoration: underline;
}
.modal__copy-btn {
  flex-shrink: 0;
  background: transparent;
  border: none;
  padding: 0.2rem 0.3rem;
  cursor: pointer;
  color: var(--ink-ghost);
  display: flex;
  align-items: center;
  transition: color 0.2s;
  line-height: 1;
}
.modal__copy-btn:hover {
  color: var(--accent);
}
.modal__copy-btn.copied {
  color: #16a34a;
}
  border-color: #16a34a;
  color: #16a34a;
}
[data-theme="dark"] .modal__url-row {
  background: #27272a;
  border-color: #3f3f46;
}
[data-theme="dark"] .modal__url-link { color: #a1a1aa; }
[data-theme="dark"] .modal__url-link:hover { color: var(--accent); }
[data-theme="dark"] .modal__copy-btn { color: #52525b; }
[data-theme="dark"] .modal__copy-btn:hover { color: var(--accent); }
[data-theme="dark"] .modal__copy-btn.copied { color: #4ade80; }

/* ── No Results ───────────────────────────────────────────────────────── */
.no-results {
  max-width: var(--max-width);
  margin: 4rem auto;
  text-align: center;
  color: var(--ink-ghost);
  display: none;
}
.no-results.visible { display: block; }
.no-results__icon { font-size: 3rem; margin-bottom: 1rem; color: var(--rule); }
.no-results__text { font-style: italic; font-size: 1.1rem; }

/* ── Footer ───────────────────────────────────────────────────────────── */
.page-footer {
  max-width: var(--max-width);
  margin: 3rem auto 0;
  padding: 1.5rem var(--gutter);
  border-top: 3px double var(--rule-heavy);
  text-align: center;
}
.page-footer__text {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  color: var(--ink-ghost);
}

/* ── Back-to-top ──────────────────────────────────────────────────────── */
.back-to-top {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  width: 2.5rem;
  height: 2.5rem;
  background: var(--ink);
  color: var(--paper);
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.3s, transform 0.3s;
  z-index: 50;
  box-shadow: 0 2px 8px var(--shadow-deep);
}
.back-to-top.visible { opacity: 1; transform: translateY(0); }
.back-to-top:hover { background: var(--accent); }

/* ── Responsive ───────────────────────────────────────────────────────── */
@media (max-width: 768px) {
  .card-grid { grid-template-columns: 1fr; }
  .card--headline { flex-direction: column; }
  .card--headline .card__image-wrap { width: 100%; aspect-ratio: 16 / 9; min-width: auto; }
  .modal__content { padding: 1.5rem 1.25rem; }
  .modal__title { font-size: 1.5rem; }
  .masthead__flourish { display: none; }
  .toolbar { gap: 0.5rem; }
}

@media (max-width: 480px) {
  .toolbar__view-btns { display: none; }
  .masthead__title { font-size: 2rem; }
}

/* ── Print ────────────────────────────────────────────────────────────── */
@media print {
  .toolbar, .back-to-top, .modal-overlay { display: none !important; }
  .card { break-inside: avoid; box-shadow: none; }
  body::before { display: none; }
}

/* ── Decorative column rule between cards (in grid mode) ──────────────── */
.card-grid:not(.card-grid--headlines) .card {
  border-left: 1px solid var(--paper-edge);
  padding-left: 0;
}
.card-grid:not(.card-grid--headlines) .card:first-child,
.card-grid:not(.card-grid--headlines) .card:nth-child(4n+1) {
  border-left: none;
}

/* ── Skeleton loading feel (applied briefly) ──────────────────────────── */
@keyframes shimmer {
  0% { background-position: -200px 0; }
  100% { background-position: calc(200px + 100%) 0; }
}

/* ── Highlight search matches ─────────────────────────────────────────── */
mark {
  background: rgba(139, 58, 58, 0.2);
  color: inherit;
  padding: 0 2px;
  border-radius: 1px;
}

/* ── Hidden utility ───────────────────────────────────────────────────── */
.hidden { display: none !important; }

/* ── Scrollbar styling ────────────────────────────────────────────────── */
::-webkit-scrollbar { width: 8px; }
::-webkit-scrollbar-track { background: var(--paper-dark); }
::-webkit-scrollbar-thumb { background: var(--rule); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: var(--ink-faded); }

/* ═══════════════════════════════════════════════════════════════════════
   DARK THEME — Neon on Charcoal
   ═══════════════════════════════════════════════════════════════════════ */
[data-theme="dark"] {
  --paper:        #1a1a1e;
  --paper-dark:   #141417;
  --paper-edge:   #2a2a30;
  --ink:          #d4d4d8;
  --ink-light:    #a1a1aa;
  --ink-faded:    #71717a;
  --ink-ghost:    #52525b;
  --accent:       #f472b6;
  --accent-hover: #f9a8d4;
  --accent-pale:  rgba(244, 114, 182, 0.2);
  --rule:         #3f3f46;
  --rule-heavy:   #52525b;
  --shadow:       rgba(0, 0, 0, 0.3);
  --shadow-deep:  rgba(0, 0, 0, 0.5);
  --texture-opacity: 0;
  color-scheme: dark;
}

[data-theme="dark"] a { color: var(--accent); }
[data-theme="dark"] a:hover { color: var(--accent-hover); }
[data-theme="dark"] ::selection { background: var(--accent-pale); color: #fff; }

/* Neon glow accents */
[data-theme="dark"] .masthead__title {
  color: #e4e4e7;
  text-shadow: 0 0 30px rgba(244, 114, 182, 0.15);
}
[data-theme="dark"] .masthead__rule-top,
[data-theme="dark"] .masthead__rule-bottom { border-color: #3f3f46; }

[data-theme="dark"] .toolbar__search-input {
  background: #27272a;
  border-color: #3f3f46;
  color: #d4d4d8;
}
[data-theme="dark"] .toolbar__search-input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 2px rgba(244, 114, 182, 0.2);
}
[data-theme="dark"] .toolbar__search-input::placeholder { color: #52525b; }

[data-theme="dark"] .toolbar__filter-btn.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #1a1a1e;
}
[data-theme="dark"] .toolbar__filter-btn[data-kind="podcast"].active,
[data-theme="dark"] .toolbar__filter-btn[data-media="audio"].active {
  background: #a78bfa;
  border-color: #a78bfa;
  color: #1a1a1e;
}
[data-theme="dark"] .toolbar__filter-btn[data-kind="video"].active,
[data-theme="dark"] .toolbar__filter-btn[data-media="video"].active,
[data-theme="dark"] .toolbar__filter-btn[data-media="youtube"].active {
  background: #fb923c;
  border-color: #fb923c;
  color: #1a1a1e;
}

[data-theme="dark"] .toolbar__view-btn.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #1a1a1e;
}

[data-theme="dark"] .tag-cloud__tag.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #1a1a1e;
}

[data-theme="dark"] .card {
  background: #27272a;
  border-color: #3f3f46;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
}
[data-theme="dark"] .card:hover {
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.5);
  border-color: var(--accent);
}
[data-theme="dark"] .card__title a { color: #e4e4e7; }
[data-theme="dark"] .card__title a:hover { color: var(--accent); }

[data-theme="dark"] .section-header__title { color: #e4e4e7; }
[data-theme="dark"] .section-header__icon { color: var(--accent); }
[data-theme="dark"] .section-header__rule { border-color: #3f3f46; }

[data-theme="dark"] .card__media-badge--audio {
  background: #a78bfa;
  color: #1a1a1e;
}
[data-theme="dark"] .card__media-badge--youtube {
  background: #fb923c;
  color: #1a1a1e;
}
[data-theme="dark"] .card__media-badge--video {
  background: #38bdf8;
  color: #1a1a1e;
}

[data-theme="dark"] .modal {
  background: #1a1a1e;
  border: 1px solid #3f3f46;
}
[data-theme="dark"] .modal__title { color: #e4e4e7; }
[data-theme="dark"] .modal__close {
  color: #a1a1aa;
  background: #27272a;
  border-color: #3f3f46;
}
[data-theme="dark"] .modal__close:hover {
  color: var(--accent);
  border-color: var(--accent);
}
[data-theme="dark"] .modal__action-btn {
  border-color: var(--accent);
  color: var(--accent);
}
[data-theme="dark"] .modal__action-btn:hover {
  background: var(--accent);
  color: #1a1a1e;
}
[data-theme="dark"] .modal__action-btn--primary {
  background: var(--accent);
  color: #1a1a1e;
}

[data-theme="dark"] .back-to-top {
  background: var(--accent);
  color: #1a1a1e;
  box-shadow: 0 2px 12px rgba(244, 114, 182, 0.3);
}
[data-theme="dark"] .back-to-top:hover {
  background: var(--accent-hover);
}

[data-theme="dark"] .page-footer { border-color: #3f3f46; }

[data-theme="dark"] ::-webkit-scrollbar-track { background: #141417; }
[data-theme="dark"] ::-webkit-scrollbar-thumb { background: #3f3f46; }
[data-theme="dark"] ::-webkit-scrollbar-thumb:hover { background: #52525b; }

[data-theme="dark"] .card-grid:not(.card-grid--headlines) .card {
  border-left-color: #3f3f46;
}

[data-theme="dark"] .filter-panel { border-bottom-color: #3f3f46; }

[data-theme="dark"] .no-results__icon { color: #52525b; }
[data-theme="dark"] mark {
  background: rgba(244, 114, 182, 0.25);
  color: #e4e4e7;
}

/* ── Theme Switcher ───────────────────────────────────────────────────── */
.theme-switcher {
  display: inline-flex;
  align-items: center;
  border: 1px solid var(--rule);
  border-radius: var(--card-radius);
  overflow: hidden;
  flex-shrink: 0;
}
.theme-switcher__btn {
  background: transparent;
  border: none;
  padding: 0.3rem 0.45rem;
  cursor: pointer;
  color: var(--ink-ghost);
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.theme-switcher__btn:not(:last-child) {
  border-right: 1px solid var(--rule);
}
.theme-switcher__btn:hover {
  color: var(--ink-light);
  background: var(--paper-dark);
}
.theme-switcher__btn.active {
  background: var(--ink);
  color: var(--paper);
}
[data-theme="dark"] .theme-switcher__btn.active {
  background: var(--accent);
  color: #1a1a1e;
}
</style>
</head>
